---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import A11yMenu from '../components/A11yMenu.astro';
import { translations } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pedro Paiva Ferreira — Desenvolvedor Web Full-Stack',
  description = 'Portfólio de Pedro Paiva Ferreira — desenvolvedor web full-stack construindo produtos reais em React, Node.js e TypeScript.',
} = Astro.props;

const i18nJson = JSON.stringify(translations);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Pedro.dev" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script is:inline set:html={`window.__I18N__ = ${i18nJson};`}></script>
  </head>
  <body>
    <div class="scroll-progress"></div>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <A11yMenu />

    <aside
      class="section-indicator"
      data-section-indicator
      aria-hidden="true"
    >
      <span class="si-dot"></span>
      <span class="si-num">01</span>
      <span class="si-sep">/</span>
      <span class="si-name">início</span>
    </aside>

    <script>
      // --- i18n: runtime language switching ---
      type Lang = 'pt' | 'en' | 'es';
      type Dict = Record<string, string>;
      const I18N = (window as any).__I18N__ as Record<Lang, Dict>;
      const VALID: Lang[] = ['pt', 'en', 'es'];
      const STORAGE_KEY = 'lang';

      const getLang = (): Lang => {
        const saved = localStorage.getItem(STORAGE_KEY) as Lang | null;
        if (saved && VALID.includes(saved)) return saved;
        const nav = (navigator.language || 'pt').slice(0, 2).toLowerCase();
        if (nav === 'en') return 'en';
        if (nav === 'es') return 'es';
        return 'pt';
      };

      // Safe HTML renderer: only allows <strong> and <em>. No innerHTML.
      const applySafeHtml = (el: Element, html: string) => {
        while (el.firstChild) el.removeChild(el.firstChild);
        const re = /<(strong|em)>([\s\S]*?)<\/\1>/g;
        let lastIdx = 0;
        for (const match of html.matchAll(re)) {
          const idx = match.index ?? 0;
          if (idx > lastIdx) {
            el.appendChild(document.createTextNode(html.slice(lastIdx, idx)));
          }
          const tag = document.createElement(match[1]);
          tag.textContent = match[2];
          el.appendChild(tag);
          lastIdx = idx + match[0].length;
        }
        if (lastIdx < html.length) {
          el.appendChild(document.createTextNode(html.slice(lastIdx)));
        }
      };

      const applyLang = (lang: Lang) => {
        const dict = I18N[lang] || I18N.pt;
        document.documentElement.lang =
          lang === 'pt' ? 'pt-BR' : lang === 'en' ? 'en-US' : 'es-ES';

        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n;
          if (key && dict[key] !== undefined) el.textContent = dict[key];
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach((el) => {
          const key = el.dataset.i18nHtml;
          if (key && dict[key] !== undefined) applySafeHtml(el, dict[key]);
        });

        const t = dict['doc.title'];
        if (t) document.title = t;
        const meta = document.querySelector<HTMLMetaElement>('meta[name="description"]');
        if (meta && dict['doc.description']) meta.content = dict['doc.description'];

        document.querySelectorAll<HTMLButtonElement>('[data-lang-switch] [data-lang]').forEach((btn) => {
          btn.setAttribute('aria-pressed', btn.dataset.lang === lang ? 'true' : 'false');
        });

        localStorage.setItem(STORAGE_KEY, lang);
        document.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
      };

      applyLang(getLang());

      document
        .querySelectorAll<HTMLButtonElement>('[data-lang-switch] [data-lang]')
        .forEach((btn) => {
          btn.addEventListener('click', () => {
            const lang = btn.dataset.lang as Lang;
            if (lang && VALID.includes(lang)) applyLang(lang);
          });
        });

      // --- Reveal on scroll (works for .reveal, .rise, .mask-rise) ---
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: '0px 0px -90px 0px' }
      );

      document
        .querySelectorAll('.reveal, .rise, .mask-rise')
        .forEach((el) => revealObserver.observe(el));

      // --- Nav compaction on scroll ---
      const nav = document.querySelector('[data-nav]');
      if (nav) {
        const onScroll = () => {
          if (window.scrollY > 24) nav.classList.add('is-scrolled');
          else nav.classList.remove('is-scrolled');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // --- Count-up animation (runs when stat enters viewport) ---
      const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
      const animateCount = (el: HTMLElement) => {
        const target = parseFloat(el.dataset.count || '0');
        const suffix = el.dataset.suffix || '';
        const duration = 1800;
        const start = performance.now();
        const step = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          const value = Math.round(target * easeOutCubic(t));
          el.textContent = value + suffix;
          if (t < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };

      const countObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateCount(entry.target as HTMLElement);
              countObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.5 }
      );

      document
        .querySelectorAll<HTMLElement>('[data-count]')
        .forEach((el) => countObserver.observe(el));

      // --- Section indicator (fixed bottom-right) ---
      const indicator = document.querySelector('[data-section-indicator]');
      if (indicator) {
        const numEl = indicator.querySelector('.si-num') as HTMLElement;
        const nameEl = indicator.querySelector('.si-name') as HTMLElement;

        const sections: { el: HTMLElement; num: string; name: string }[] = [
          { num: '01', name: 'início' },
          { num: '02', name: 'sobre' },
          { num: '03', name: 'skills' },
          { num: '04', name: 'projetos' },
          { num: '05', name: 'github' },
          { num: '06', name: 'contato' },
        ]
          .map((s, i) => {
            const ids = ['top', 'sobre', 'skills', 'projetos', 'github', 'contato'];
            const el = document.getElementById(ids[i]);
            return el ? { el, ...s } : null;
          })
          .filter(Boolean) as any;

        let current = '';
        const updateIndicator = () => {
          const y = window.scrollY + window.innerHeight * 0.35;
          let active = sections[0];
          for (const s of sections) {
            if (s.el.offsetTop <= y) active = s;
          }
          if (active && active.num !== current) {
            current = active.num;
            numEl.textContent = active.num;
            nameEl.textContent = active.name;
          }
          if (window.scrollY > 120) indicator.classList.add('is-on');
          else indicator.classList.remove('is-on');
        };
        window.addEventListener('scroll', updateIndicator, { passive: true });
        updateIndicator();
      }
    </script>
  </body>
</html>

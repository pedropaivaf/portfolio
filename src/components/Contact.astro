---
import { Icon } from 'astro-icon/components';

const methods = [
  {
    icon: 'lucide:mail',
    label: 'Email',
    value: 'contato.pedropaivaf@outlook.com',
    href: 'mailto:contato.pedropaivaf@outlook.com',
  },
  {
    icon: 'lucide:message-circle',
    label: 'WhatsApp',
    value: '+55 32 98401-9757',
    href: 'https://wa.me/5532984019757?text=Ol%C3%A1%20Pedro%2C%20quero%20conversar%20sobre%20um%20projeto',
  },
  {
    icon: 'lucide:linkedin',
    label: 'LinkedIn',
    value: 'pedropaivaf',
    href: 'https://www.linkedin.com/in/pedropaivaf/',
  },
  {
    icon: 'lucide:github',
    label: 'GitHub',
    value: 'pedropaivaf',
    href: 'https://github.com/pedropaivaf',
  },
];
---

<section id="contato" class="section">
  <div class="container-page">
    <div class="contact-card reveal">
      <div class="contact-head">
        <span class="eyebrow" data-i18n="contact.eyebrow">// 05 — contato</span>
        <h2 class="h-section" data-i18n="contact.title">Vamos construir algo juntos?</h2>
        <p class="contact-lead" data-i18n="contact.lead">
          Estou disponível para novos projetos freelance e oportunidades full-stack. Me chama no canal
          que preferir — respondo rápido.
        </p>
      </div>

      <div class="contact-grid">
        {methods.map((m, i) => (
          <a
            href={m.href}
            target={m.href.startsWith('http') ? '_blank' : undefined}
            rel="noopener"
            class="contact-item reveal"
            style={`--reveal-delay: ${150 + i * 90}ms`}
          >
            <span class="contact-icon">
              <Icon name={m.icon} width="18" height="18" />
            </span>
            <div class="contact-text">
              <span class="contact-label">{m.label}</span>
              <span class="contact-value">{m.value}</span>
            </div>
            <Icon name="lucide:arrow-up-right" width="16" height="16" class="contact-arrow" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section { padding: clamp(3.5rem, 9vw, 6rem) 0; }

  .contact-card {
    background: var(--bg-code);
    color: var(--text-inverse);
    border-radius: 1.1rem;
    padding: 1.5rem 1.25rem;
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, white 8%, transparent);
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 560px) {
    .contact-card {
      padding: 2rem 1.75rem;
      border-radius: 1.25rem;
    }
  }

  @media (min-width: 900px) {
    .contact-card {
      padding: 3.25rem;
    }
  }

  .contact-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(ellipse 70% 60% at 30% 30%, black 30%, transparent 100%);
    pointer-events: none;
  }

  .contact-card::after {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, #22c55e, transparent 70%);
    opacity: 0.25;
    pointer-events: none;
    filter: blur(20px);
  }

  .contact-head {
    position: relative;
    z-index: 1;
    margin-bottom: 2.25rem;
    max-width: 36rem;
  }

  .contact-head .eyebrow {
    color: #94a3b8;
  }

  .contact-head .h-section {
    color: #ffffff;
    margin-top: 0.5rem;
  }

  .contact-lead {
    color: #cbd5e1;
    margin-top: 0.85rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .contact-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1rem;
    border-radius: 0.7rem;
    border: 1px solid color-mix(in oklab, white 10%, transparent);
    background: color-mix(in oklab, white 4%, transparent);
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    min-width: 0;
  }

  @media (min-width: 560px) {
    .contact-item {
      gap: 1rem;
      padding: 1.05rem 1.2rem;
    }
  }

  .contact-item:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: color-mix(in oklab, var(--accent) 12%, transparent);
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 0.5rem;
    background: color-mix(in oklab, white 8%, transparent);
    color: var(--accent);
    flex-shrink: 0;
  }

  .contact-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
  }

  .contact-value {
    color: #f8fafc;
    font-size: 0.85rem;
    font-weight: 500;
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.35;
  }

  @media (min-width: 560px) {
    .contact-value {
      font-size: 0.9rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      word-break: normal;
    }
  }

  .contact-arrow {
    color: #94a3b8;
    transition: transform 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .contact-item:hover .contact-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
</style>

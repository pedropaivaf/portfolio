---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<article class="card project-card reveal" style={`--reveal-delay: ${index * 90}ms`}>
  <div class="project-media">
    <Image src={project.image} alt={project.name} class="project-img" widths={[600]} sizes="(max-width: 768px) 100vw, 560px" />
    <span class="project-num">{num}</span>
    {project.status === 'live' && <span class="badge-live project-badge" data-i18n="project.badge.live">em produção</span>}
  </div>

  <div class="project-body">
    <header class="project-head">
      <h3 class="h-card">{project.name}</h3>
      <p class="project-tagline" data-i18n={`project.${project.slug}.tagline`}>{project.tagline}</p>
    </header>

    <p class="project-desc" data-i18n={`project.${project.slug}.description`}>{project.description}</p>

    <div class="project-stack">
      {project.stack.map((s) => <span class="chip">{s}</span>)}
    </div>

    <div class="project-actions">
      {project.live && (
        <a href={project.live} target="_blank" rel="noopener" class="btn btn-primary btn-sm">
          <Icon name="lucide:external-link" width="14" height="14" />
          <span data-i18n="project.cta.site">Ver site</span>
        </a>
      )}
      {project.repo && (
        <a href={project.repo} target="_blank" rel="noopener" class="btn btn-ghost btn-sm">
          <Icon name="lucide:github" width="14" height="14" />
          <span data-i18n="project.cta.code">Código</span>
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .project-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--bg-code);
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-img {
    transform: scale(1.04);
  }

  .project-num {
    position: absolute;
    top: 0.85rem;
    left: 0.95rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: #cbd5e1;
    padding: 0.25rem 0.5rem;
    background: rgba(15, 23, 42, 0.7);
    border-radius: 0.3rem;
    backdrop-filter: blur(4px);
  }

  .project-badge {
    position: absolute;
    top: 0.85rem;
    right: 0.95rem;
  }

  .project-body {
    padding: 1.4rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .project-head {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .project-tagline {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent-strong);
  }

  .project-desc {
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.65;
    flex: 1;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .project-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }
</style>

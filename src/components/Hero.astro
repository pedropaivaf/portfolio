---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import HeroTerminal from './HeroTerminal.astro';
import avatar from '../assets/perfil.jpg';
---

<section id="top" class="hero">
  <div class="grid-bg hero-bg" aria-hidden="true"></div>
  <div class="hero-blob-1" aria-hidden="true"></div>
  <div class="hero-blob-2" aria-hidden="true"></div>

  <div class="container-page hero-inner">
    <div class="hero-content">
      <span class="eyebrow reveal">// Bem-Vindo(a) ao meu perfil.</span>

      <h1 class="h-display rise" style="--reveal-delay: 80ms">
        Pedro<br />
        Paiva<span class="dot">.</span>
        <span class="accent-underline">Ferreira</span>
      </h1>

      <p class="hero-lead reveal" style="--reveal-delay: 260ms">
        <span class="syn-kw">let</span>
        <span class="syn-fn">role</span>
        <span class="muted">=</span>
        <span class="syn-str">"Full-Stack Developer"</span>
        <span class="muted">;</span>
        <br />
        <span class="syn-cmt">// evoluindo → Cloud · IA · Mobile</span>
      </p>

      <p class="hero-bio reveal" style="--reveal-delay: 380ms">
        Construo produtos web <strong>reais em produção</strong> — de sistemas de gestão a plataformas
        de reserva. Foco em interfaces rápidas, código limpo e resultados que funcionam.
      </p>

      <div class="hero-ctas reveal" style="--reveal-delay: 500ms">
        <a href="#projetos" class="btn btn-primary">
          <Icon name="lucide:arrow-down-right" width="16" height="16" />
          Ver projetos
        </a>
        <a href="https://github.com/pedropaivaf" target="_blank" rel="noopener" class="btn btn-ghost">
          <Icon name="lucide:github" width="16" height="16" />
          GitHub
        </a>
      </div>

      <div class="hero-meta reveal" style="--reveal-delay: 620ms">
        <div class="meta-item">
          <Icon name="lucide:map-pin" width="14" height="14" />
          <span>Juiz de Fora, MG</span>
        </div>
        <div class="meta-item">
          <span class="dot-live"></span>
          <span>Disponível para projetos</span>
        </div>
        <div class="meta-item">
          <Icon name="lucide:graduation-cap" width="14" height="14" />
          <span>Sistemas de Informação — UniAcademia (7º período)</span>
        </div>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="hero-avatar-wrap">
        <Image src={avatar} alt="Pedro Paiva Ferreira" class="hero-avatar" />
        <span class="hero-avatar-ring" aria-hidden="true"></span>
      </div>
      <HeroTerminal />
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span class="font-mono">scroll</span>
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 7rem;
    padding-bottom: 4rem;
    overflow: hidden;
    min-height: 100svh;
  }

  @media (min-width: 640px) {
    .hero {
      padding-top: 9rem;
      padding-bottom: 5rem;
    }
  }

  @media (min-width: 960px) {
    .hero {
      padding-top: 10rem;
      padding-bottom: 6rem;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-blob-1,
  .hero-blob-2 {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  .hero-blob-1 {
    width: clamp(260px, 60vw, 420px);
    height: clamp(260px, 60vw, 420px);
    background: radial-gradient(circle, #22c55e, transparent 70%);
    top: 6%;
    right: -12%;
  }

  .hero-blob-2 {
    width: clamp(220px, 50vw, 360px);
    height: clamp(220px, 50vw, 360px);
    background: radial-gradient(circle, #6366f1, transparent 70%);
    bottom: -10%;
    left: -10%;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 1.15fr 1fr;
      gap: 4rem;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .h-display .dot {
    color: var(--accent);
  }

  .accent-underline {
    position: relative;
    display: inline-block;
  }

  .accent-underline::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.1em;
    height: 0.25em;
    background: color-mix(in oklab, var(--accent) 45%, transparent);
    z-index: -1;
    border-radius: 2px;
  }

  .hero-lead {
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--text);
  }

  .muted {
    color: var(--text-muted);
  }

  .hero-bio {
    font-size: clamp(1rem, 1.3vw, 1.1rem);
    color: var(--text-muted);
    max-width: 34rem;
    line-height: 1.7;
  }

  .hero-bio strong {
    color: var(--text);
    font-weight: 700;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--border);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-muted);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot-live {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 60%, transparent);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-avatar-wrap {
    position: relative;
    width: clamp(160px, 48vw, 260px);
    height: clamp(160px, 48vw, 260px);
  }

  .hero-avatar {
    width: 100%;
    height: 100%;
    border-radius: 1.25rem;
    box-shadow: var(--shadow-lg);
    border: 2px solid var(--bg-elev);
    object-fit: cover;
    object-position: center 20%;
  }

  .hero-avatar-ring {
    position: absolute;
    inset: -10px;
    border-radius: 1.6rem;
    border: 1.5px dashed color-mix(in oklab, var(--accent) 70%, transparent);
    animation: spin 25s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    z-index: 1;
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scroll-down 2s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; }
    50% { transform: scaleY(1); }
  }
</style>

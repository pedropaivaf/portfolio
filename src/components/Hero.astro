---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import HeroTerminal from './HeroTerminal.astro';
import avatar from '../assets/perfil.jpg';
---

<section id="top" class="hero">
  <div class="grid-bg hero-bg" aria-hidden="true"></div>
  <div class="hero-blob-1" aria-hidden="true"></div>
  <div class="hero-blob-2" aria-hidden="true"></div>

  <div class="container-page hero-inner">
    <div class="hero-content">
      <span class="eyebrow reveal" data-i18n="hero.eyebrow">// Bem-Vindo(a) ao meu perfil.</span>

      <h1 class="h-display rise" style="--reveal-delay: 80ms">
        Pedro<br />
        Paiva<span class="dot">.</span>
        <span class="accent-underline">Ferreira</span>
      </h1>

      <p class="hero-lead reveal" style="--reveal-delay: 260ms">
        <span class="syn-kw">let</span>
        <span class="syn-fn">role</span>
        <span class="muted">=</span>
        <span class="syn-str" data-i18n="hero.role">"Full-Stack Developer"</span>
        <span class="muted">;</span>
        <br />
        <span class="syn-cmt" data-i18n="hero.comment">// evoluindo → Cloud · IA · Mobile</span>
      </p>

      <p class="hero-bio reveal" style="--reveal-delay: 380ms" data-i18n-html="hero.bio">
        Construo produtos web <strong>reais em produção</strong> — de sistemas de gestão a plataformas
        de reserva. Foco em interfaces rápidas, código limpo e resultados que funcionam.
      </p>

      <div class="hero-ctas reveal" style="--reveal-delay: 500ms">
        <a href="#projetos" class="btn btn-primary">
          <Icon name="lucide:arrow-down-right" width="16" height="16" />
          <span data-i18n="hero.cta.projects">Ver projetos</span>
        </a>
        <a href="https://github.com/pedropaivaf" target="_blank" rel="noopener" class="btn btn-ghost">
          <Icon name="lucide:github" width="16" height="16" />
          <span data-i18n="hero.cta.github">GitHub</span>
        </a>
      </div>

      <div class="hero-meta reveal" style="--reveal-delay: 620ms">
        <div class="meta-item">
          <Icon name="lucide:map-pin" width="14" height="14" />
          <span data-i18n="hero.meta.location">Juiz de Fora, MG</span>
        </div>
        <div class="meta-item">
          <span class="dot-live"></span>
          <span data-i18n="hero.meta.available">Disponível para projetos</span>
        </div>
        <div class="meta-item">
          <Icon name="lucide:graduation-cap" width="14" height="14" />
          <span data-i18n="hero.meta.edu">Sistemas de Informação — UniAcademia (7º período)</span>
        </div>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="hero-avatar-wrap">
        <span class="hv-ghost" aria-hidden="true">P</span>
        <span class="hv-tag">SUBJECT-01</span>
        <span class="hv-ts" aria-hidden="true">2026.04.13 · 14:32</span>

        <span class="hv-offset" aria-hidden="true"></span>
        <Image src={avatar} alt="Pedro Paiva Ferreira" class="hero-avatar" />
        <span class="hv-scan" aria-hidden="true"></span>

        <svg class="hv-corner hv-tl" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M0 6 H12 M6 0 V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <svg class="hv-corner hv-tr" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M0 6 H12 M6 0 V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <svg class="hv-corner hv-bl" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M0 6 H12 M6 0 V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <svg class="hv-corner hv-br" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M0 6 H12 M6 0 V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>

        <div class="hv-row" aria-hidden="true">
          <span>pedro.paiva_ferreira</span>
          <span class="hv-sep">::</span>
          <span>full_stack</span>
          <span class="hv-sep">::</span>
          <span>br</span>
          <span class="hv-sep">::</span>
          <span>v2.6</span>
          <span class="hv-caret">▊</span>
        </div>
      </div>
      <HeroTerminal />
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span class="font-mono" data-i18n="hero.scroll">scroll</span>
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 7rem;
    padding-bottom: 4rem;
    overflow: hidden;
    min-height: 100svh;
  }

  @media (min-width: 640px) {
    .hero {
      padding-top: 9rem;
      padding-bottom: 5rem;
    }
  }

  @media (min-width: 960px) {
    .hero {
      padding-top: 10rem;
      padding-bottom: 6rem;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-blob-1,
  .hero-blob-2 {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  .hero-blob-1 {
    width: clamp(260px, 60vw, 420px);
    height: clamp(260px, 60vw, 420px);
    background: radial-gradient(circle, #22c55e, transparent 70%);
    top: 6%;
    right: -12%;
  }

  .hero-blob-2 {
    width: clamp(220px, 50vw, 360px);
    height: clamp(220px, 50vw, 360px);
    background: radial-gradient(circle, #6366f1, transparent 70%);
    bottom: -10%;
    left: -10%;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 1.15fr 1fr;
      gap: 4rem;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .h-display .dot {
    color: var(--accent);
  }

  .accent-underline {
    position: relative;
    display: inline-block;
  }

  .accent-underline::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.1em;
    height: 0.25em;
    background: color-mix(in oklab, var(--accent) 45%, transparent);
    z-index: -1;
    border-radius: 2px;
  }

  .hero-lead {
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--text);
  }

  .muted {
    color: var(--text-muted);
  }

  .hero-bio {
    font-size: clamp(1rem, 1.3vw, 1.1rem);
    color: var(--text-muted);
    max-width: 34rem;
    line-height: 1.7;
  }

  .hero-bio strong {
    color: var(--text);
    font-weight: 700;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--border);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-muted);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot-live {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 60%, transparent);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-visual {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  .hero-avatar-wrap {
    position: relative;
    width: clamp(180px, 48vw, 280px);
    height: clamp(180px, 48vw, 280px);
    isolation: isolate;
    overflow: visible;
  }

  /* ------- ghost "P" monogram ------- */
  .hv-ghost {
    position: absolute;
    top: -26%;
    left: -18%;
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: clamp(240px, 42vw, 380px);
    line-height: 0.78;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in oklab, var(--accent) 48%, transparent);
    transform: rotate(-4deg);
    z-index: 0;
    pointer-events: none;
    user-select: none;
    opacity: 0;
    animation: hv-ghost-in 0.8s 0.05s ease-out forwards;
    transition: -webkit-text-stroke-width 0.3s ease, opacity 0.3s ease;
  }
  @keyframes hv-ghost-in {
    from { opacity: 0; transform: rotate(-4deg) translate(-12px, 8px); }
    to   { opacity: 0.9; transform: rotate(-4deg) translate(0, 0); }
  }

  /* ------- indigo offset misregister plate ------- */
  .hv-offset {
    position: absolute;
    inset: 0;
    transform: translate(-8px, 8px);
    background: color-mix(in oklab, var(--accent-2) 18%, var(--bg-elev));
    border: 1px solid color-mix(in oklab, var(--accent-2) 45%, transparent);
    clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 0 100%);
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    animation: hv-plate-in 0.5s 0.18s ease-out forwards;
  }
  @keyframes hv-plate-in {
    from { opacity: 0; transform: translate(-2px, 2px); }
    to   { opacity: 1; transform: translate(-8px, 8px); }
  }

  /* ------- avatar image ------- */
  .hero-avatar {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 0 100%);
    border: none;
    box-shadow:
      3px 0 0 color-mix(in oklab, var(--accent) 55%, transparent),
      -3px 0 0 color-mix(in oklab, var(--accent-2) 55%, transparent),
      var(--shadow-md);
    transition: box-shadow 0.25s ease, transform 0.18s ease;
    opacity: 0;
    animation: hv-img-in 0.5s 0.26s ease-out forwards;
  }
  @keyframes hv-img-in {
    from { opacity: 0; clip-path: polygon(0 0, 0 0, 0 100%, 0 100%, 0 100%); }
    to   { opacity: 1; clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 0 100%); }
  }

  /* ------- scanline overlay (clipped to match image) ------- */
  .hv-scan {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 0 100%);
    background: repeating-linear-gradient(
      0deg,
      transparent 0 2px,
      rgba(15, 23, 42, 0.14) 2px 3px
    );
    mix-blend-mode: multiply;
    opacity: 0;
    animation:
      hv-scan-fade 0.5s 0.4s ease forwards,
      hv-scan-drift 6s 0.4s linear infinite;
  }
  @keyframes hv-scan-fade {
    to { opacity: 0.55; }
  }
  @keyframes hv-scan-drift {
    to { background-position-y: 3px; }
  }

  /* ------- registration-mark crosses ------- */
  .hv-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    color: var(--accent);
    z-index: 4;
    stroke-dasharray: 24;
    stroke-dashoffset: 24;
    animation: hv-draw 0.4s ease forwards;
  }
  .hv-tl { top: -10px;    left: -10px;   animation-delay: 0.44s; }
  .hv-tr { top: -10px;    right: -10px;  animation-delay: 0.52s; }
  .hv-bl { bottom: -10px; left: -10px;   animation-delay: 0.60s; }
  .hv-br { bottom: -10px; right: -10px;  animation-delay: 0.68s; }
  @keyframes hv-draw { to { stroke-dashoffset: 0; } }

  /* ------- top-left dossier tag ------- */
  .hv-tag {
    position: absolute;
    top: -26px;
    left: 2px;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--accent-strong);
    z-index: 5;
    display: inline-flex;
    align-items: center;
    opacity: 0;
    animation: hv-fade-up 0.35s 0.66s ease forwards;
  }
  .hv-tag::before {
    content: '';
    display: inline-block;
    width: 16px;
    height: 1.5px;
    background: currentColor;
    margin-right: 0.55rem;
  }

  /* ------- top-right timestamp chip ------- */
  .hv-ts {
    position: absolute;
    top: -14px;
    right: -14px;
    padding: 0.22rem 0.55rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    box-shadow: var(--shadow-sm);
    z-index: 5;
    white-space: nowrap;
    opacity: 0;
    animation: hv-fade-up 0.35s 0.74s ease forwards;
  }

  @keyframes hv-fade-up {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ------- bottom data strip ------- */
  .hv-row {
    position: absolute;
    left: -8px;
    right: -8px;
    bottom: -36px;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    padding-top: 0.55rem;
    border-top: 1px dashed color-mix(in oklab, var(--accent) 45%, transparent);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    z-index: 5;
    white-space: nowrap;
  }
  .hv-row > span {
    clip-path: inset(0 100% 0 0);
    animation: hv-type 0.32s ease forwards;
  }
  .hv-row > span:nth-child(1) { animation-delay: 0.82s; }
  .hv-row > span:nth-child(2) { animation-delay: 0.90s; }
  .hv-row > span:nth-child(3) { animation-delay: 0.98s; }
  .hv-row > span:nth-child(4) { animation-delay: 1.06s; }
  .hv-row > span:nth-child(5) { animation-delay: 1.14s; }
  .hv-row > span:nth-child(6) { animation-delay: 1.22s; }
  .hv-row > span:nth-child(7) { animation-delay: 1.30s; }
  .hv-sep { color: color-mix(in oklab, var(--accent) 70%, var(--text-muted)); }
  @keyframes hv-type { to { clip-path: inset(0 0 0 0); } }

  .hv-caret {
    color: var(--accent);
    animation: hv-caret 1.1s steps(1) 1.38s infinite;
  }
  @keyframes hv-caret {
    0%, 49%   { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* ------- hover glitch (desktop only, respects reduced motion) ------- */
  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .hero-avatar-wrap:hover .hero-avatar {
      box-shadow:
        5px 0 0 color-mix(in oklab, var(--accent) 65%, transparent),
        -5px 0 0 color-mix(in oklab, var(--accent-2) 65%, transparent),
        var(--shadow-md);
      animation: hv-glitch 0.22s steps(3) 1;
    }
    .hero-avatar-wrap:hover .hv-ghost {
      opacity: 1;
      -webkit-text-stroke-width: 2px;
    }
    .hero-avatar-wrap:hover .hv-scan { opacity: 0.75; }
  }
  @keyframes hv-glitch {
    0%   { transform: translateX(0); }
    33%  { transform: translateX(2px); }
    66%  { transform: translateX(-2px); }
    100% { transform: translateX(0); }
  }

  /* ------- reduced motion: skip animations, show final state ------- */
  @media (prefers-reduced-motion: reduce) {
    .hv-ghost,
    .hv-offset,
    .hero-avatar,
    .hv-scan,
    .hv-tag,
    .hv-ts,
    .hv-corner,
    .hv-row > span,
    .hv-caret {
      animation: none;
    }
    .hv-ghost { opacity: 0.9; transform: rotate(-4deg); }
    .hv-offset { opacity: 1; }
    .hero-avatar { opacity: 1; }
    .hv-scan { opacity: 0.55; }
    .hv-tag, .hv-ts { opacity: 1; transform: none; }
    .hv-corner { stroke-dashoffset: 0; }
    .hv-row > span { clip-path: inset(0 0 0 0); }
    .hv-caret { opacity: 1; }
  }

  /* ------- mobile adjustments: kill the dark shadow, scale ghost ------- */
  @media (max-width: 640px) {
    .hero-avatar-wrap {
      width: clamp(170px, 62vw, 220px);
      height: clamp(170px, 62vw, 220px);
    }
    .hv-ghost {
      font-size: clamp(200px, 68vw, 260px);
      left: -22%;
      top: -22%;
    }
    .hero-avatar {
      box-shadow:
        2px 0 0 color-mix(in oklab, var(--accent) 55%, transparent),
        -2px 0 0 color-mix(in oklab, var(--accent-2) 55%, transparent);
    }
    .hv-scan { opacity: 0.38; }
    .hv-corner { width: 10px; height: 10px; }
    .hv-tl, .hv-tr { top: -7px; }
    .hv-bl, .hv-br { bottom: -7px; }
    .hv-tl, .hv-bl { left: -7px; }
    .hv-tr, .hv-br { right: -7px; }
    .hv-row {
      font-size: 0.54rem;
      bottom: -32px;
      left: -4px;
      right: -4px;
    }
    .hv-tag { top: -22px; font-size: 0.62rem; }
  }
  @media (max-width: 420px) {
    .hv-ts { display: none; }
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    z-index: 1;
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scroll-down 2s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; }
    50% { transform: scaleY(1); }
  }
</style>

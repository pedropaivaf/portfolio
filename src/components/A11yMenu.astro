---
import { Icon } from 'astro-icon/components';
---

<button
  type="button"
  class="a11y-fab"
  data-a11y-toggle
  data-i18n-aria="a11y.open"
  aria-label="Abrir menu de acessibilidade"
  aria-expanded="false"
  aria-controls="a11y-panel"
>
  <svg
    class="a11y-fab-icon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width="22"
    height="22"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10" />
    <circle cx="12" cy="6.2" r="1.25" fill="currentColor" stroke="none" />
    <path d="M5 10.2 h14" />
    <path d="M12 7.8 v6.4" />
    <path d="M12 14.2 l-3 5.6" />
    <path d="M12 14.2 l3 5.6" />
  </svg>
  <span class="a11y-fab-label" data-i18n="a11y.fab">Acessibilidade</span>
</button>

<div class="a11y-scrim" data-a11y-scrim aria-hidden="true"></div>

<aside
  id="a11y-panel"
  class="a11y-panel"
  data-a11y-panel
  aria-hidden="true"
  role="dialog"
  aria-modal="false"
  aria-label="Opções de acessibilidade"
>
  <header class="a11y-head">
    <h2 data-i18n="a11y.title">Acessibilidade</h2>
    <button
      type="button"
      class="a11y-close"
      data-a11y-close
      data-i18n-aria="a11y.close"
      aria-label="Fechar menu"
    >
      <Icon name="lucide:x" width="18" height="18" />
    </button>
  </header>

  <div class="a11y-body">
    <div class="a11y-group">
      <span class="a11y-label" data-i18n="a11y.fontSize">Tamanho do texto</span>
      <div
        class="a11y-font-btns"
        role="group"
        data-i18n-aria="a11y.fontSize"
        aria-label="Tamanho do texto"
      >
        <button type="button" data-font="sm" data-i18n-aria="a11y.font.sm" aria-label="Pequeno">A-</button>
        <button type="button" data-font="md" class="is-active" data-i18n-aria="a11y.font.md" aria-label="Normal">A</button>
        <button type="button" data-font="lg" data-i18n-aria="a11y.font.lg" aria-label="Grande">A+</button>
        <button type="button" data-font="xl" data-i18n-aria="a11y.font.xl" aria-label="Extra grande">A++</button>
      </div>
    </div>

    <div class="a11y-group">
      <span class="a11y-label" data-i18n="a11y.section.visual">Visualização</span>
      <div class="a11y-toggles">
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="dark" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:moon" width="16" height="16" />
            <span data-i18n="a11y.opt.dark">Modo escuro</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="contrast" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:contrast" width="16" height="16" />
            <span data-i18n="a11y.opt.contrast">Alto contraste</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="grayscale" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:droplet" width="16" height="16" />
            <span data-i18n="a11y.opt.grayscale">Escala de cinza</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="invert" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:sun-moon" width="16" height="16" />
            <span data-i18n="a11y.opt.invert">Inverter cores</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="saturate" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:palette" width="16" height="16" />
            <span data-i18n="a11y.opt.saturate">Saturação reduzida</span>
          </span>
        </label>
      </div>
    </div>

    <div class="a11y-group">
      <span class="a11y-label" data-i18n="a11y.section.reading">Leitura</span>
      <div class="a11y-toggles">
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="dyslexia" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:book-open" width="16" height="16" />
            <span data-i18n="a11y.opt.dyslexia">Fonte para dislexia</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="spacing" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:align-justify" width="16" height="16" />
            <span data-i18n="a11y.opt.spacing">Espaçamento ampliado</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="links" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:link" width="16" height="16" />
            <span data-i18n="a11y.opt.links">Sublinhar links</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="guide" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:minus" width="16" height="16" />
            <span data-i18n="a11y.opt.guide">Guia de leitura</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="hideImages" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:image-off" width="16" height="16" />
            <span data-i18n="a11y.opt.hideImages">Ocultar imagens</span>
          </span>
        </label>
      </div>
    </div>

    <div class="a11y-group">
      <span class="a11y-label" data-i18n="a11y.section.interaction">Interação</span>
      <div class="a11y-toggles">
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="motion" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:pause" width="16" height="16" />
            <span data-i18n="a11y.opt.motion">Reduzir animações</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="cursor" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:mouse-pointer-2" width="16" height="16" />
            <span data-i18n="a11y.opt.cursor">Cursor grande</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="focus" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:focus" width="16" height="16" />
            <span data-i18n="a11y.opt.focus">Destaque no foco</span>
          </span>
        </label>
        <label class="a11y-toggle">
          <input type="checkbox" data-opt="lefty" />
          <span class="a11y-switch"></span>
          <span class="a11y-text">
            <Icon name="lucide:hand" width="16" height="16" />
            <span data-i18n="a11y.opt.lefty">Modo canhoto</span>
          </span>
        </label>
      </div>
    </div>

    <div class="a11y-group">
      <div class="a11y-label-row">
        <span class="a11y-label" data-i18n="a11y.section.tts">Leitor de tela (áudio)</span>
        <button
          type="button"
          class="a11y-tracks-toggle"
          data-tracks-toggle
          aria-pressed="false"
          data-i18n-aria="a11y.tracks.aria"
          aria-label="Mostrar botões de leitura em cada seção"
        >
          <Icon name="lucide:list-music" width="13" height="13" />
          <span data-i18n="a11y.tracks">Trechos</span>
        </button>
      </div>
      <div class="a11y-tts" data-a11y-tts>
        <div class="a11y-tts-row">
          <button type="button" class="a11y-tts-btn a11y-tts-play" data-tts-play>
            <Icon name="lucide:play" width="16" height="16" />
            <span>Ouvir página</span>
          </button>
          <button
            type="button"
            class="a11y-tts-icon"
            data-tts-stop
            data-i18n-aria="a11y.tts.stop"
            aria-label="Parar leitura"
          >
            <Icon name="lucide:square" width="14" height="14" />
          </button>
        </div>
        <div class="a11y-tts-speed">
          <span class="a11y-tts-speed-label" data-i18n="a11y.tts.speed">Velocidade</span>
          <input type="range" min="0.7" max="1.6" step="0.1" value="1" data-tts-rate />
          <span class="a11y-tts-speed-value" data-tts-rate-value>1.0x</span>
        </div>
        <p class="a11y-tts-status" data-tts-status>Pronto para ler o conteúdo.</p>
      </div>
    </div>

    <button type="button" class="a11y-reset" data-a11y-reset>
      <Icon name="lucide:rotate-ccw" width="14" height="14" />
      <span data-i18n="a11y.reset">Resetar tudo</span>
    </button>

    <p class="a11y-note" data-i18n="a11y.note">
      Suas preferências ficam salvas neste dispositivo.
    </p>
  </div>
</aside>

<div class="a11y-reading-guide" data-a11y-guide aria-hidden="true"></div>

<style is:global>
  /* ---------- FAB button ---------- */
  .a11y-fab {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 9995;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 0.95rem;
    background: var(--accent);
    color: #0b1220;
    border: 1px solid color-mix(in oklab, #000 15%, var(--accent));
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(34, 197, 94, 0.35),
      0 0 0 0 color-mix(in oklab, var(--accent) 60%, transparent);
    transition: transform 0.25s ease, box-shadow 0.3s ease;
    animation: a11y-pulse 2.8s ease-in-out infinite;
  }

  .a11y-fab:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 16px 40px rgba(34, 197, 94, 0.5);
  }

  .a11y-fab:focus-visible {
    outline: 3px solid var(--accent-2);
    outline-offset: 3px;
  }

  .a11y-fab-label {
    display: none;
  }

  @media (min-width: 560px) {
    .a11y-fab-label {
      display: inline;
    }
  }

  @keyframes a11y-pulse {
    0%, 100% { box-shadow: 0 10px 30px rgba(34, 197, 94, 0.35), 0 0 0 0 rgba(34, 197, 94, 0.45); }
    50%      { box-shadow: 0 10px 30px rgba(34, 197, 94, 0.35), 0 0 0 12px rgba(34, 197, 94, 0); }
  }

  /* ---------- Scrim ---------- */
  .a11y-scrim {
    position: fixed;
    inset: 0;
    background: rgba(11, 18, 32, 0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    z-index: 9996;
    transition: opacity 0.3s ease;
  }
  .a11y-scrim.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ---------- Panel ---------- */
  .a11y-panel {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    max-width: 420px;
    max-height: min(88vh, 720px);
    z-index: 9997;
    background: #ffffff;
    color: #0b1220;
    border: 1px solid #e3e7ee;
    border-radius: 1.1rem;
    box-shadow: 0 30px 80px rgba(15, 23, 42, 0.3);
    transform: translateY(calc(100% + 2rem)) scale(0.98);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @media (min-width: 560px) {
    .a11y-panel {
      left: 1.25rem;
      right: auto;
      width: 380px;
      bottom: 5rem;
    }
  }

  .a11y-panel.is-open {
    transform: translateY(0) scale(1);
    opacity: 1;
    pointer-events: auto;
  }

  .a11y-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.25rem 0.85rem;
    border-bottom: 1px solid #e3e7ee;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, #22c55e 10%, #ffffff) 0%,
      #ffffff 100%
    );
  }

  .a11y-head h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0b1220;
    margin: 0;
  }

  .a11y-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: #f7f8fa;
    border: 1px solid #e3e7ee;
    color: #0b1220;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .a11y-close:hover {
    background: #eef2f7;
    border-color: #cbd5e1;
    transform: rotate(90deg);
  }

  .a11y-body {
    padding: 1rem 1.25rem 1.25rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    flex: 1 1 auto;
    min-height: 0;
  }

  .a11y-body::-webkit-scrollbar {
    width: 8px;
  }
  .a11y-body::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 999px;
  }
  .a11y-body::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  .a11y-group {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .a11y-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #5b6472;
  }

  /* Font size buttons */
  .a11y-font-btns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.35rem;
  }

  .a11y-font-btns button {
    padding: 0.55rem 0.25rem;
    border-radius: 0.55rem;
    border: 1px solid #e3e7ee;
    background: #ffffff;
    color: #0b1220;
    font-family: var(--font-sans);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .a11y-font-btns button:nth-child(1) { font-size: 0.72rem; }
  .a11y-font-btns button:nth-child(2) { font-size: 0.88rem; }
  .a11y-font-btns button:nth-child(3) { font-size: 1.02rem; }
  .a11y-font-btns button:nth-child(4) { font-size: 1.18rem; }

  .a11y-font-btns button:hover {
    border-color: #22c55e;
    background: color-mix(in oklab, #22c55e 10%, #ffffff);
  }

  .a11y-font-btns button.is-active {
    border-color: #22c55e;
    background: #22c55e;
    color: #0b1220;
    box-shadow: 0 6px 14px rgba(34, 197, 94, 0.25);
  }

  /* Toggles */
  .a11y-toggles {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .a11y-toggle {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0.7rem;
    border-radius: 0.6rem;
    border: 1px solid #e3e7ee;
    background: #f7f8fa;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .a11y-toggle:hover {
    border-color: #22c55e;
    background: color-mix(in oklab, #22c55e 7%, #f7f8fa);
  }

  .a11y-toggle input {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }

  .a11y-switch {
    position: relative;
    width: 34px;
    height: 20px;
    border-radius: 999px;
    background: #cbd5e1;
    flex-shrink: 0;
    transition: background 0.25s ease;
  }

  .a11y-switch::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .a11y-toggle input:checked + .a11y-switch {
    background: #22c55e;
  }

  .a11y-toggle input:checked + .a11y-switch::after {
    transform: translateX(14px);
  }

  .a11y-toggle input:focus-visible + .a11y-switch {
    outline: 2px solid #6366f1;
    outline-offset: 2px;
  }

  .a11y-text {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: #0b1220;
    flex: 1;
  }

  .a11y-text svg { color: #5b6472; flex-shrink: 0; }

  /* ---------- Label row with inline action ---------- */
  .a11y-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .a11y-tracks-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    border: 1px solid #e3e7ee;
    background: #ffffff;
    color: #0b1220;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .a11y-tracks-toggle:hover {
    border-color: #22c55e;
    background: color-mix(in oklab, #22c55e 8%, #ffffff);
  }
  .a11y-tracks-toggle[aria-pressed="true"] {
    background: #22c55e;
    border-color: #22c55e;
    color: #0b1220;
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }

  /* ---------- Per-section "Ouvir" buttons injected into the page ---------- */
  .a11y-track-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    border: 1px solid #22c55e;
    background: #22c55e;
    color: #0b1220;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(34, 197, 94, 0.35);
    animation: a11y-track-pulse 2.6s ease-in-out infinite;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .a11y-track-btn:hover {
    transform: translateY(-2px);
    background: #16a34a;
    color: #ffffff;
  }
  .a11y-track-btn[data-state="playing"] {
    background: #f59e0b;
    border-color: #f59e0b;
    animation: none;
  }
  .a11y-track-btn svg { flex-shrink: 0; }

  @keyframes a11y-track-pulse {
    0%, 100% { box-shadow: 0 8px 20px rgba(34, 197, 94, 0.35), 0 0 0 0 rgba(34, 197, 94, 0.5); }
    50%      { box-shadow: 0 8px 20px rgba(34, 197, 94, 0.35), 0 0 0 10px rgba(34, 197, 94, 0); }
  }

  @media (max-width: 560px) {
    .a11y-track-btn {
      top: 0.6rem;
      right: 0.6rem;
      padding: 0.4rem 0.7rem;
      font-size: 0.6rem;
    }
  }

  /* ---------- TTS (screen reader) ---------- */
  .a11y-tts {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.75rem;
    border-radius: 0.6rem;
    border: 1px solid #e3e7ee;
    background: #f7f8fa;
  }

  .a11y-tts-row {
    display: flex;
    gap: 0.5rem;
  }

  .a11y-tts-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 0.85rem;
    border-radius: 0.55rem;
    border: 1px solid #22c55e;
    background: #22c55e;
    color: #0b1220;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .a11y-tts-btn:hover {
    background: #16a34a;
    color: #ffffff;
    transform: translateY(-1px);
  }
  .a11y-tts-btn[data-state="playing"] { background: #f59e0b; border-color: #f59e0b; }
  .a11y-tts-btn[data-state="paused"]  { background: #6366f1; border-color: #6366f1; color: #fff; }

  .a11y-tts-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 0.55rem;
    border: 1px solid #e3e7ee;
    background: #ffffff;
    color: #0b1220;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .a11y-tts-icon:hover {
    background: #fef2f2;
    border-color: #fca5a5;
    color: #b91c1c;
  }

  .a11y-tts-speed {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.72rem;
    color: #5b6472;
  }
  .a11y-tts-speed-label {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .a11y-tts-speed input[type="range"] {
    width: 100%;
    accent-color: #22c55e;
  }
  .a11y-tts-speed-value {
    font-family: var(--font-mono);
    font-weight: 600;
    color: #0b1220;
    min-width: 2.5rem;
    text-align: right;
  }

  .a11y-tts-status {
    margin: 0;
    font-size: 0.72rem;
    color: #5b6472;
    font-style: italic;
  }

  .a11y-reset {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.7rem 1rem;
    border-radius: 0.6rem;
    border: 1px solid #e3e7ee;
    background: #ffffff;
    color: #0b1220;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .a11y-reset:hover {
    background: #fef2f2;
    border-color: #fca5a5;
    color: #b91c1c;
  }

  .a11y-note {
    margin: 0;
    font-size: 0.7rem;
    color: #5b6472;
    text-align: center;
    font-style: italic;
  }

  /* ---------- Reading guide ---------- */
  .a11y-reading-guide {
    position: fixed;
    left: 0;
    right: 0;
    height: 46px;
    top: 0;
    background: rgba(250, 204, 21, 0.14);
    border-top: 2px solid #facc15;
    border-bottom: 2px solid #facc15;
    pointer-events: none;
    z-index: 9998;
    display: none;
    transform: translateY(-50%);
    box-shadow: 0 0 60px rgba(250, 204, 21, 0.25);
  }
  html.a11y-guide .a11y-reading-guide { display: block; }

  /* ======================================================
     ACCESSIBILITY MODES — classes applied on <html>
     ====================================================== */

  /* Font sizes */
  html.a11y-font-sm { font-size: 87.5%; }
  html.a11y-font-md { font-size: 100%; }
  html.a11y-font-lg { font-size: 115%; }
  html.a11y-font-xl { font-size: 130%; }

  /* Dark mode */
  html.a11y-dark {
    --bg: #0b1220;
    --bg-elev: #111a2e;
    --text: #f8fafc;
    --text-muted: #94a3b8;
    --border: #1e293b;
    --border-strong: #334155;
  }
  html.a11y-dark body { background: #0b1220; color: #f8fafc; }
  html.a11y-dark .card,
  html.a11y-dark .contact-item { background: #111a2e; color: #f8fafc; }

  /* High contrast */
  html.a11y-contrast {
    --bg: #000000;
    --bg-elev: #000000;
    --bg-code: #000000;
    --bg-code-2: #000000;
    --text: #ffffff;
    --text-muted: #ffff00;
    --text-inverse: #ffffff;
    --border: #ffffff;
    --border-strong: #ffffff;
    --accent: #00ff88;
    --accent-strong: #00ff88;
    --accent-2: #ffff00;
  }
  html.a11y-contrast body { background: #000; color: #fff; }
  html.a11y-contrast *,
  html.a11y-contrast *::before,
  html.a11y-contrast *::after {
    text-shadow: none !important;
    box-shadow: none !important;
  }
  html.a11y-contrast a { color: #ffff00 !important; text-decoration: underline !important; }
  html.a11y-contrast button,
  html.a11y-contrast .btn {
    border: 2px solid #fff !important;
  }

  /* Grayscale / Invert / Saturate — apply to siblings of the a11y UI so the
     menu stays visible and the FAB keeps its fixed positioning (filters on
     body would create a new stacking context and break position:fixed). */
  html.a11y-grayscale body > *:not(.a11y-fab):not(.a11y-panel):not(.a11y-scrim):not(.a11y-reading-guide) {
    filter: grayscale(1);
  }

  html.a11y-invert body > *:not(.a11y-fab):not(.a11y-panel):not(.a11y-scrim):not(.a11y-reading-guide) {
    filter: invert(1) hue-rotate(180deg);
  }
  html.a11y-invert img,
  html.a11y-invert video,
  html.a11y-invert picture { filter: invert(1) hue-rotate(180deg); }

  html.a11y-saturate body > *:not(.a11y-fab):not(.a11y-panel):not(.a11y-scrim):not(.a11y-reading-guide) {
    filter: saturate(0.55);
  }

  /* Dyslexia-friendly font */
  html.a11y-dyslexia body,
  html.a11y-dyslexia .h-display,
  html.a11y-dyslexia .h-section,
  html.a11y-dyslexia p,
  html.a11y-dyslexia span,
  html.a11y-dyslexia li,
  html.a11y-dyslexia a,
  html.a11y-dyslexia button {
    font-family: Verdana, 'Trebuchet MS', 'Comic Sans MS', sans-serif !important;
    letter-spacing: 0.04em;
    word-spacing: 0.12em;
  }
  html.a11y-dyslexia body { line-height: 1.9 !important; }

  /* Extra spacing */
  html.a11y-spacing body {
    letter-spacing: 0.08em !important;
    word-spacing: 0.2em !important;
    line-height: 2 !important;
  }
  html.a11y-spacing p,
  html.a11y-spacing li { margin-bottom: 0.85em !important; }

  /* Underline all links */
  html.a11y-links a {
    text-decoration: underline !important;
    text-underline-offset: 3px !important;
    text-decoration-thickness: 2px !important;
  }

  /* Hide images */
  html.a11y-hideImages img,
  html.a11y-hideImages picture,
  html.a11y-hideImages video {
    visibility: hidden !important;
    background: repeating-linear-gradient(45deg, #e3e7ee, #e3e7ee 10px, #f7f8fa 10px, #f7f8fa 20px) !important;
  }

  /* Reduce motion */
  html.a11y-motion *,
  html.a11y-motion *::before,
  html.a11y-motion *::after {
    animation-duration: 0.001s !important;
    animation-delay: 0s !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001s !important;
    transition-delay: 0s !important;
    scroll-behavior: auto !important;
  }
  html.a11y-motion .reveal,
  html.a11y-motion .rise,
  html.a11y-motion .mask-rise { opacity: 1 !important; transform: none !important; mask-image: none !important; }

  /* Big cursor */
  html.a11y-cursor,
  html.a11y-cursor * {
    cursor: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="%2322c55e" fill-opacity="0.35" stroke="%2322c55e" stroke-width="3"/><circle cx="24" cy="24" r="3" fill="%2322c55e"/></svg>') 24 24, auto !important;
  }
  html.a11y-cursor a,
  html.a11y-cursor button,
  html.a11y-cursor [role="button"] {
    cursor: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="%236366f1" fill-opacity="0.4" stroke="%236366f1" stroke-width="3"/><circle cx="24" cy="24" r="3" fill="%236366f1"/></svg>') 24 24, pointer !important;
  }

  /* Strong focus ring */
  html.a11y-focus *:focus,
  html.a11y-focus *:focus-visible {
    outline: 3px solid #facc15 !important;
    outline-offset: 3px !important;
    box-shadow: 0 0 0 6px rgba(250, 204, 21, 0.3) !important;
  }

  /* ---------- Reading highlight (TTS) ---------- */
  /* Soft underline that follows every line of the block being read.
     text-decoration is painted under the text itself, never clipped by
     parents with overflow: hidden, and naturally wraps with the lines. */
  .a11y-reading {
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 65%, transparent);
    text-decoration-thickness: 2px;
    text-underline-offset: 5px;
    text-decoration-skip-ink: auto;
    transition: text-decoration-color 0.3s ease;
    animation: a11y-reading-pulse 2.4s ease-in-out infinite;
    scroll-margin-top: 6rem;
    scroll-margin-bottom: 6rem;
  }

  /* Make sure descendants inherit the soft underline color even if
     they declare their own text-decoration. */
  .a11y-reading * {
    text-decoration-color: inherit;
  }

  @keyframes a11y-reading-pulse {
    0%, 100% {
      text-decoration-color: color-mix(in oklab, var(--accent) 55%, transparent);
    }
    50% {
      text-decoration-color: color-mix(in oklab, var(--accent) 100%, transparent);
    }
  }

  html.a11y-motion .a11y-reading {
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .a11y-reading {
      animation: none;
    }
  }
</style>

<script>
  type Opt =
    | 'dark'
    | 'contrast'
    | 'grayscale'
    | 'invert'
    | 'saturate'
    | 'dyslexia'
    | 'spacing'
    | 'links'
    | 'guide'
    | 'hideImages'
    | 'motion'
    | 'cursor'
    | 'focus'
    | 'lefty'
    | 'tracks';

  type FontSize = 'sm' | 'md' | 'lg' | 'xl';

  interface A11yState {
    font: FontSize;
    opts: Partial<Record<Opt, boolean>>;
  }

  const KEY = 'a11y-prefs';
  const html = document.documentElement;

  // ---------- i18n helpers ----------
  type Lang = 'pt' | 'en' | 'es';
  const I18N = (window as any).__I18N__ as Record<Lang, Record<string, string>> | undefined;
  const getLang = (): Lang => {
    const l = localStorage.getItem('lang');
    if (l === 'en' || l === 'es') return l;
    return 'pt';
  };
  const t = (key: string, vars?: Record<string, string | number>): string => {
    const lang = getLang();
    let s = (I18N?.[lang]?.[key] ?? I18N?.pt?.[key] ?? key) as string;
    if (vars) {
      for (const k of Object.keys(vars)) {
        s = s.replace(`{${k}}`, String(vars[k]));
      }
    }
    return s;
  };
  const bcp47 = (lang: Lang): string =>
    lang === 'en' ? 'en-US' : lang === 'es' ? 'es-ES' : 'pt-BR';

  const load = (): A11yState => {
    try {
      const raw = localStorage.getItem(KEY);
      if (raw) return JSON.parse(raw);
    } catch {}
    return { font: 'md', opts: {} };
  };

  const save = (s: A11yState) => {
    try {
      localStorage.setItem(KEY, JSON.stringify(s));
    } catch {}
  };

  const state = load();

  const applyFont = (size: FontSize) => {
    ['sm', 'md', 'lg', 'xl'].forEach((s) => html.classList.remove(`a11y-font-${s}`));
    html.classList.add(`a11y-font-${size}`);
    document.querySelectorAll<HTMLButtonElement>('.a11y-font-btns button').forEach((b) => {
      b.classList.toggle('is-active', b.dataset.font === size);
    });
  };

  const applyOpt = (opt: Opt, on: boolean) => {
    html.classList.toggle(`a11y-${opt}`, on);
    const input = document.querySelector<HTMLInputElement>(`input[data-opt="${opt}"]`);
    if (input) input.checked = on;
  };

  // Initial apply (tracks is handled separately after TTS setup)
  applyFont(state.font || 'md');
  (Object.keys(state.opts || {}) as Opt[]).forEach((k) => {
    if (k === 'tracks') return;
    if (state.opts[k]) applyOpt(k, true);
  });

  // Font size buttons
  document.querySelectorAll<HTMLButtonElement>('.a11y-font-btns button').forEach((b) => {
    b.addEventListener('click', () => {
      const size = (b.dataset.font as FontSize) || 'md';
      state.font = size;
      applyFont(size);
      save(state);
    });
  });

  // Toggles
  document.querySelectorAll<HTMLInputElement>('input[data-opt]').forEach((input) => {
    input.addEventListener('change', () => {
      const opt = input.dataset.opt as Opt;
      const on = input.checked;
      state.opts[opt] = on;
      applyOpt(opt, on);
      save(state);
    });
  });

  // Reset
  const resetBtn = document.querySelector('[data-a11y-reset]');
  resetBtn?.addEventListener('click', () => {
    ['sm', 'md', 'lg', 'xl'].forEach((s) => html.classList.remove(`a11y-font-${s}`));
    [
      'dark', 'contrast', 'grayscale', 'invert', 'saturate',
      'dyslexia', 'spacing', 'links', 'guide', 'hideImages',
      'motion', 'cursor', 'focus', 'lefty',
    ].forEach((o) => html.classList.remove(`a11y-${o}`));
    document.querySelectorAll<HTMLInputElement>('input[data-opt]').forEach((i) => (i.checked = false));
    disableTracks();
    stopReading();
    state.font = 'md';
    state.opts = {};
    applyFont('md');
    save(state);
  });

  // Panel open/close
  const fab = document.querySelector<HTMLButtonElement>('[data-a11y-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-a11y-panel]');
  const scrim = document.querySelector<HTMLElement>('[data-a11y-scrim]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-a11y-close]');

  const openPanel = () => {
    panel?.classList.add('is-open');
    scrim?.classList.add('is-open');
    panel?.setAttribute('aria-hidden', 'false');
    fab?.setAttribute('aria-expanded', 'true');
  };
  const closePanel = () => {
    panel?.classList.remove('is-open');
    scrim?.classList.remove('is-open');
    panel?.setAttribute('aria-hidden', 'true');
    fab?.setAttribute('aria-expanded', 'false');
  };

  fab?.addEventListener('click', () => {
    if (panel?.classList.contains('is-open')) closePanel();
    else openPanel();
  });
  closeBtn?.addEventListener('click', closePanel);
  scrim?.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
  });

  // Reading guide follows cursor
  const guide = document.querySelector<HTMLElement>('[data-a11y-guide]');
  document.addEventListener('mousemove', (e) => {
    if (!html.classList.contains('a11y-guide') || !guide) return;
    guide.style.top = `${e.clientY}px`;
  });

  // ---------- Text-to-speech (screen reader) ----------
  const synth = 'speechSynthesis' in window ? window.speechSynthesis : null;
  const playBtn = document.querySelector<HTMLButtonElement>('[data-tts-play]');
  const stopBtn = document.querySelector<HTMLButtonElement>('[data-tts-stop]');
  const rateInput = document.querySelector<HTMLInputElement>('[data-tts-rate]');
  const rateValue = document.querySelector<HTMLElement>('[data-tts-rate-value]');
  const statusEl = document.querySelector<HTMLElement>('[data-tts-status]');
  const playLabel = playBtn?.querySelector('span');

  type Chunk = { text: string; el: HTMLElement };
  let chunks: Chunk[] = [];
  let chunkIndex = 0;
  let ttsState: 'idle' | 'playing' | 'paused' = 'idle';
  let keepAliveInterval: number | null = null;
  let highlightedEl: HTMLElement | null = null;

  const prefersReducedMotion = (): boolean =>
    html.classList.contains('a11y-motion') ||
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const clearHighlight = () => {
    if (highlightedEl) {
      highlightedEl.classList.remove('a11y-reading');
      highlightedEl = null;
    }
  };

  const highlightEl = (el: HTMLElement) => {
    if (highlightedEl === el) return;
    clearHighlight();
    el.classList.add('a11y-reading');
    highlightedEl = el;
    el.scrollIntoView({
      behavior: prefersReducedMotion() ? 'auto' : 'smooth',
      block: 'center',
    });
  };

  // Track current status message in an i18n-aware way so langchange can re-render it.
  let currentStatusKey: { key: string; vars?: Record<string, string | number> } = {
    key: 'a11y.tts.status.ready',
  };

  const setStatus = (key: string, vars?: Record<string, string | number>) => {
    currentStatusKey = { key, vars };
    if (statusEl) statusEl.textContent = t(key, vars);
  };

  const setPlayUi = (state: 'idle' | 'playing' | 'paused') => {
    ttsState = state;
    if (!playBtn || !playLabel) return;
    if (state === 'playing') {
      playBtn.dataset.state = 'playing';
      playLabel.textContent = t('a11y.tts.pause');
      playBtn.setAttribute('aria-label', t('a11y.tts.pause.aria'));
    } else if (state === 'paused') {
      playBtn.dataset.state = 'paused';
      playLabel.textContent = t('a11y.tts.resume');
      playBtn.setAttribute('aria-label', t('a11y.tts.resume.aria'));
    } else {
      delete playBtn.dataset.state;
      playLabel.textContent = t('a11y.tts.play');
      playBtn.setAttribute('aria-label', t('a11y.tts.play.aria'));
    }
  };

  const pickVoice = (lang: Lang): SpeechSynthesisVoice | null => {
    if (!synth) return null;
    const voices = synth.getVoices();
    const prefix = lang === 'pt' ? 'pt' : lang === 'en' ? 'en' : 'es';
    const filtered = voices.filter((v) =>
      v.lang?.toLowerCase().startsWith(prefix)
    );
    return (
      filtered.find((v) => /google/i.test(v.name)) ||
      filtered.find((v) => /natural|neural|online|wavenet/i.test(v.name)) ||
      filtered.find((v) => /microsoft/i.test(v.name)) ||
      filtered[0] ||
      voices[0] ||
      null
    );
  };

  const normalizeForSpeech = (raw: string): string => {
    const arrow = t('a11y.speech.arrow');
    const slash = t('a11y.speech.slash');
    const and = t('a11y.speech.and');
    const plus = t('a11y.speech.plus');
    return raw
      .replace(/\s+/g, ' ')
      .replace(/[—–]/g, ', ')        // em/en dash → pause
      .replace(/→/g, arrow)          // arrow
      .replace(/·/g, ', ')           // middle dot (Cloud · IA · Mobile)
      .replace(/\//g, slash)         // "frontend/backend" → "frontend or backend"
      .replace(/&/g, and)
      .replace(/\+/g, plus)
      .replace(/[{}[\]<>«»"'`]/g, ' ')
      .replace(/\.{2,}/g, '.')       // collapse "..." → "."
      .replace(/\s+([.,;:!?])/g, '$1')
      .replace(/([.,;:!?])(?=[^\s])/g, '$1 ')
      .replace(/,\s*,+/g, ',')
      .replace(/\s{2,}/g, ' ')
      .trim();
  };

  const BLOCK_SELECTOR =
    'h1, h2, h3, h4, h5, h6, p, li, blockquote, figcaption, dt, dd, .output-line';
  const SKIP_SELECTOR =
    'script, style, .a11y-track-btn, .eyebrow, .syn-cmt, [aria-hidden="true"]';

  const extractText = (root: HTMLElement | null): Chunk[] => {
    if (!root) return [];
    const result: Chunk[] = [];
    const blocks = Array.from(
      root.querySelectorAll<HTMLElement>(BLOCK_SELECTOR)
    ).filter((el) => !el.closest(SKIP_SELECTOR));

    const sources: HTMLElement[] = blocks.length > 0 ? blocks : [root];

    for (const el of sources) {
      const clone = el.cloneNode(true) as HTMLElement;
      clone.querySelectorAll(SKIP_SELECTOR).forEach((n) => n.remove());
      const raw = clone.innerText || clone.textContent || '';
      const normalized = normalizeForSpeech(raw);
      const pieces = normalized
        .split(/(?<=[.!?;])\s+/)
        .flatMap((s) => (s.length <= 180 ? [s] : s.split(/(?<=,)\s+(?=\w)/)))
        .map((s) => s.trim())
        .filter((s) => s.length > 0);
      pieces.forEach((text) => result.push({ text, el }));
    }
    return result;
  };

  let activeTrackBtn: HTMLButtonElement | null = null;
  const clearActiveTrackBtn = () => {
    if (activeTrackBtn) {
      delete activeTrackBtn.dataset.state;
      activeTrackBtn = null;
    }
  };

  const stopKeepAlive = () => {
    if (keepAliveInterval !== null) {
      window.clearInterval(keepAliveInterval);
      keepAliveInterval = null;
    }
  };

  const startKeepAlive = () => {
    stopKeepAlive();
    // Chrome kills long speech after ~15s. Poking pause/resume keeps it going.
    keepAliveInterval = window.setInterval(() => {
      if (synth && ttsState === 'playing' && synth.speaking && !synth.paused) {
        synth.pause();
        synth.resume();
      }
    }, 10000);
  };

  const speakNext = () => {
    if (!synth) return;
    if (chunkIndex >= chunks.length) {
      setPlayUi('idle');
      stopKeepAlive();
      clearActiveTrackBtn();
      clearHighlight();
      setStatus('a11y.tts.status.done');
      return;
    }
    const current = chunks[chunkIndex];
    const utter = new SpeechSynthesisUtterance(current.text);
    const lang = getLang();
    const voice = pickVoice(lang);
    if (voice) utter.voice = voice;
    utter.lang = voice?.lang || bcp47(lang);
    utter.rate = parseFloat(rateInput?.value || '1');
    utter.pitch = 1;
    utter.volume = 1;
    utter.onstart = () => {
      // Highlight only when speech actually starts. Doing it before
      // synth.speak() (with smooth scroll) was racing with Chrome's
      // cancel/speak pipeline and silencing the audio.
      highlightEl(current.el);
    };
    utter.onend = () => {
      chunkIndex += 1;
      if (ttsState !== 'playing') return;
      const prev = chunks[chunkIndex - 1];
      const gap = /[.!?]$/.test(prev?.text || '') ? 240 : 140;
      window.setTimeout(() => {
        if (ttsState === 'playing') speakNext();
      }, gap);
    };
    utter.onerror = () => {
      setStatus('a11y.tts.status.error');
      setPlayUi('idle');
      stopKeepAlive();
      clearActiveTrackBtn();
      clearHighlight();
    };
    synth.speak(utter);
    setStatus('a11y.tts.status.reading', {
      current: chunkIndex + 1,
      total: chunks.length,
    });
  };

  const startReadingFrom = (root: HTMLElement | null, label?: string) => {
    if (!synth) {
      setStatus('a11y.tts.status.unsupported');
      return;
    }
    synth.cancel();
    clearActiveTrackBtn();
    chunks = extractText(root);
    if (chunks.length === 0) {
      setStatus('a11y.tts.status.empty');
      return;
    }
    chunkIndex = 0;
    setPlayUi('playing');
    startKeepAlive();
    if (label) setStatus('a11y.tts.status.readingSection', { label });
    speakNext();
  };

  const startReading = () => startReadingFrom(document.querySelector('main'));

  const pauseReading = () => {
    if (!synth) return;
    synth.pause();
    setPlayUi('paused');
    setStatus('a11y.tts.status.paused');
  };

  const resumeReading = () => {
    if (!synth) return;
    synth.resume();
    setPlayUi('playing');
    setStatus('a11y.tts.status.reading', {
      current: chunkIndex + 1,
      total: chunks.length,
    });
  };

  const stopReading = () => {
    if (!synth) return;
    synth.cancel();
    chunkIndex = 0;
    chunks = [];
    setPlayUi('idle');
    stopKeepAlive();
    clearActiveTrackBtn();
    clearHighlight();
    setStatus('a11y.tts.status.stopped');
  };

  // ---------- Per-section (track) buttons ----------
  const sectionLabel = (id: string): string => {
    const key = `a11y.section.${id}`;
    const val = t(key);
    return val === key ? id : val;
  };

  const readSection = (section: HTMLElement, btn: HTMLButtonElement) => {
    const label = sectionLabel(section.id);
    startReadingFrom(section, label);
    activeTrackBtn = btn;
    btn.dataset.state = 'playing';
  };

  const SVG_NS = 'http://www.w3.org/2000/svg';

  const makeTrackBtn = (section: HTMLElement): HTMLButtonElement => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'a11y-track-btn';
    btn.dataset.sectionId = section.id;
    const label = sectionLabel(section.id);
    btn.setAttribute('aria-label', t('a11y.track.aria', { label }));

    const svg = document.createElementNS(SVG_NS, 'svg');
    svg.setAttribute('xmlns', SVG_NS);
    svg.setAttribute('width', '14');
    svg.setAttribute('height', '14');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'currentColor');
    svg.setAttribute('aria-hidden', 'true');
    const path = document.createElementNS(SVG_NS, 'path');
    path.setAttribute('d', 'M8 5v14l11-7z');
    svg.appendChild(path);

    const span = document.createElement('span');
    span.textContent = t('a11y.track.listen', { label });

    btn.appendChild(svg);
    btn.appendChild(span);

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (activeTrackBtn === btn && ttsState === 'playing') {
        stopReading();
      } else {
        readSection(section, btn);
      }
    });
    return btn;
  };

  const enableTracks = () => {
    document.querySelectorAll<HTMLElement>('main section[id]').forEach((section) => {
      if (section.querySelector(':scope > .a11y-track-btn')) return;
      const cs = getComputedStyle(section);
      if (cs.position === 'static') section.style.position = 'relative';
      section.appendChild(makeTrackBtn(section));
    });
    html.classList.add('a11y-tracks');
    tracksBtn?.setAttribute('aria-pressed', 'true');
  };

  const disableTracks = () => {
    document.querySelectorAll('.a11y-track-btn').forEach((b) => b.remove());
    html.classList.remove('a11y-tracks');
    tracksBtn?.setAttribute('aria-pressed', 'false');
    clearActiveTrackBtn();
  };

  const tracksBtn = document.querySelector<HTMLButtonElement>('[data-tracks-toggle]');
  tracksBtn?.addEventListener('click', () => {
    const on = tracksBtn.getAttribute('aria-pressed') === 'true';
    if (on) {
      disableTracks();
      state.opts.tracks = false;
    } else {
      enableTracks();
      state.opts.tracks = true;
    }
    save(state);
  });

  if (state.opts.tracks) {
    requestAnimationFrame(() => enableTracks());
  }

  playBtn?.addEventListener('click', () => {
    if (ttsState === 'idle') startReading();
    else if (ttsState === 'playing') pauseReading();
    else if (ttsState === 'paused') resumeReading();
  });

  stopBtn?.addEventListener('click', stopReading);

  rateInput?.addEventListener('input', () => {
    const v = parseFloat(rateInput.value).toFixed(1);
    if (rateValue) rateValue.textContent = `${v}x`;
    // Rate changes apply to the next utterance in the queue
  });

  // Pre-load voices (some browsers populate asynchronously)
  if (synth) {
    synth.onvoiceschanged = () => { /* voices ready */ };
  } else if (playBtn) {
    playBtn.disabled = true;
    setStatus('a11y.tts.status.unsupported');
  }

  // Initial idle UI so play button and status text reflect the active language
  // on first render (also re-applied on every langchange below).
  setPlayUi('idle');
  setStatus(currentStatusKey.key, currentStatusKey.vars);

  // ---------- React to language changes ----------
  // BaseLayout.applyLang re-translates [data-i18n] / [data-i18n-aria] nodes for us.
  // Here we only re-render the dynamic TTS bits that the script itself owns.
  const syncDynamicI18n = () => {
    // Re-apply play-button label + aria for the current ttsState.
    setPlayUi(ttsState);
    // Re-apply last status message (with its vars, so counters stay correct).
    setStatus(currentStatusKey.key, currentStatusKey.vars);
    // Re-render per-section track buttons (span + aria-label) without
    // recreating the nodes, so their click handlers stay attached.
    document.querySelectorAll<HTMLButtonElement>('.a11y-track-btn').forEach((btn) => {
      const id = btn.dataset.sectionId || '';
      const label = sectionLabel(id);
      btn.setAttribute('aria-label', t('a11y.track.aria', { label }));
      const span = btn.querySelector('span');
      if (span) span.textContent = t('a11y.track.listen', { label });
    });
  };

  document.addEventListener('langchange', syncDynamicI18n);

  // Stop reading when user navigates away
  window.addEventListener('beforeunload', () => {
    synth?.cancel();
    stopKeepAlive();
  });
</script>
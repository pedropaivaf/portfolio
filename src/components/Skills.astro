---
import SectionTitle from './SectionTitle.astro';
import { Icon } from 'astro-icon/components';

type Skill = { name: string; icon: string; color?: string; href: string };

const groups: { title: string; key: string; items: Skill[] }[] = [
  {
    title: 'Linguagens',
    key: 'skills.group.languages',
    items: [
      { name: 'JavaScript', icon: 'simple-icons:javascript', color: '#f7df1e', href: 'https://developer.mozilla.org/docs/Web/JavaScript' },
      { name: 'TypeScript', icon: 'simple-icons:typescript', color: '#3178c6', href: 'https://www.typescriptlang.org' },
      { name: 'Python', icon: 'simple-icons:python', color: '#3776ab', href: 'https://www.python.org' },
      { name: 'SQL', icon: 'lucide:database', color: '#6366f1', href: 'https://www.postgresql.org/docs/current/sql.html' },
      { name: 'HTML5', icon: 'simple-icons:html5', color: '#e34f26', href: 'https://developer.mozilla.org/docs/Web/HTML' },
      { name: 'CSS3', icon: 'simple-icons:css3', color: '#1572b6', href: 'https://developer.mozilla.org/docs/Web/CSS' },
    ],
  },
  {
    title: 'Frontend',
    key: 'skills.group.frontend',
    items: [
      { name: 'React', icon: 'simple-icons:react', color: '#61dafb', href: 'https://react.dev' },
      { name: 'Vue.js', icon: 'simple-icons:vuedotjs', color: '#4fc08d', href: 'https://vuejs.org' },
      { name: 'Astro', icon: 'simple-icons:astro', color: '#ff5d01', href: 'https://astro.build' },
      { name: 'Tailwind CSS', icon: 'simple-icons:tailwindcss', color: '#06b6d4', href: 'https://tailwindcss.com' },
      { name: 'Vite', icon: 'simple-icons:vite', color: '#646cff', href: 'https://vite.dev' },
    ],
  },
  {
    title: 'Backend & Desktop',
    key: 'skills.group.backend',
    items: [
      { name: 'Node.js', icon: 'simple-icons:nodedotjs', color: '#339933', href: 'https://nodejs.org' },
      { name: 'Express', icon: 'simple-icons:express', color: '#000000', href: 'https://expressjs.com' },
      { name: 'Django', icon: 'simple-icons:django', color: '#092e20', href: 'https://www.djangoproject.com' },
      { name: 'Electron', icon: 'simple-icons:electron', color: '#47848f', href: 'https://www.electronjs.org' },
    ],
  },
  {
    title: 'Dados & Ferramentas',
    key: 'skills.group.data',
    items: [
      { name: 'PostgreSQL', icon: 'simple-icons:postgresql', color: '#4169e1', href: 'https://www.postgresql.org' },
      { name: 'Supabase', icon: 'simple-icons:supabase', color: '#3ecf8e', href: 'https://supabase.com' },
      { name: 'SQLite', icon: 'simple-icons:sqlite', color: '#003b57', href: 'https://www.sqlite.org' },
      { name: 'Git & GitHub', icon: 'simple-icons:git', color: '#f05032', href: 'https://github.com' },
      { name: 'IA / LLMs', icon: 'lucide:sparkles', color: '#a855f7', href: 'https://www.anthropic.com' },
    ],
  },
];
---

<section id="skills" class="section section-alt">
  <div class="container-page">
    <SectionTitle
      eyebrow="// 02 — skills"
      title="Tecnologias que uso no dia a dia"
      lead="Stack full-stack moderna, com foco em produtividade e código de qualidade."
      eyebrowKey="skills.eyebrow"
      titleKey="skills.title"
      leadKey="skills.lead"
    />

    <div class="skills-grid">
      {groups.map((group, i) => (
        <div class="skills-group reveal" style={`--reveal-delay: ${i * 110}ms`}>
          <h3 class="skills-group-title">
            <span class="skills-group-num">//</span>
            <span data-i18n={group.key}>{group.title}</span>
          </h3>
          <div class="skills-items">
            {group.items.map((s) => (
              <a
                class="skill-chip"
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.name} — site oficial`}
                style={`--icon-color: ${s.color ?? '#0b1220'}`}
              >
                <Icon name={s.icon} width="18" height="18" />
                <span>{s.name}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: clamp(3.5rem, 9vw, 6rem) 0;
  }

  .section-alt {
    background: linear-gradient(to bottom, transparent, color-mix(in oklab, var(--text) 2%, transparent), transparent);
    position: relative;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 720px) {
    .skills-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1100px) {
    .skills-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .skills-group-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .skills-group-num {
    color: var(--accent);
  }

  .skills-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.85rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 0.55rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .skill-chip :global(svg) {
    color: var(--icon-color);
  }

  .skill-chip:hover {
    transform: translateY(-2px) scale(1.02);
    border-color: var(--icon-color);
    box-shadow: 0 4px 14px color-mix(in oklab, var(--icon-color) 20%, transparent);
  }
</style>
